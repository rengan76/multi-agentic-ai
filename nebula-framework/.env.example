# Azure OpenAI
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# OpenAI (fallback)
OPENAI_API_KEY=your-key-here

# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# LLM Mode: 'azure' | 'openai' | 'mock'
LLM_PROVIDER=mock

# Database: 'sqlite' | 'postgres' | 'mongodb' | 'memory'
DB_DRIVER=sqlite
DB_PATH=./data/nebula.db

# PostgreSQL (when DB_DRIVER=postgres)
# DB_POSTGRES_URL=postgres://user:pass@localhost:5432/nebula

# MongoDB (when DB_DRIVER=mongodb)
# DB_MONGO_URL=mongodb://localhost:27017/nebula

# Gate Configuration
MAX_RETRIES=2
RETRY_DELAY=1000
GATE_STRICT_MODE=true
